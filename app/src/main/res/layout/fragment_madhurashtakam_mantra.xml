<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFA73B"
    android:orientation="vertical"
    android:weightSum="1"
    tools:context=".ui.mantra.madhurashtakam.MadhurashtakamMantraFragment">

    <ScrollView
        android:id="@+id/madhurashtakam_mantra_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentBottom="true"
        android:layout_gravity="center"
        android:background="#FFA73B"
        android:theme="@android:style/Theme.DeviceDefault.Wallpaper"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/madhurashtakam_mantra_image">

        <TextView
            android:id="@+id/madhurashtakam_mantra_text"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:breakStrategy="high_quality"
            android:lineSpacingExtra="8sp"
            android:padding="@dimen/activity_horizontal_margin"
            android:singleLine="false"
            android:text="@string/madhurashtakammantravalue"
            android:textAlignment="center"
            android:textColor="@color/abc_primary_text_material_light"
            android:textIsSelectable="false"
            android:textSize="24sp"
            android:visibility="visible" />
    </ScrollView>

    <ImageView
        android:id="@+id/madhurashtakam_mantra_image"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginStart="139dp"
        android:layout_marginEnd="138dp"
        android:src="@drawable/krishna"
        android:contentDescription="@string/menu_madhurashtakam_mantra"
        app:layout_constraintBottom_toTopOf="@+id/madhurashtakam_mantra_scroll"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>